# Normalize line endings across platforms
* text=auto

# Force LF for source/config
*.cs        text eol=lf
*.cshtml    text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.md        text eol=lf

# Binary assets
*.png       binary
*.jpg       binary
*.jpeg      binary
*.ico       binary
