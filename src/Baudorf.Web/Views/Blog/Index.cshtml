@model List<BlogPost>
@{
    ViewData["Title"] = "Markt & Insights";
    ViewData["MetaDescription"] = "Marktanalysen, Investment-Wissen und Neubau-Trends — Expertenwissen für kluge Investoren von Baudorf Immobilien.";
}

<section class="hx-pagehead">
    <img class="hx-pagehead__emblem" src="~/img/brand/baudorf-emblem-gold.png" alt="" />
    <div class="hx-wrap">
        <div class="hx-eyebrow"><span>Markt &amp; Insights</span></div>
        <h1>Expertenwissen für <em class="hx-em">kluge Investoren</em></h1>
        <p>Fundierte Einordnungen zu Off-Market, Kapitalanlage und Projektentwicklung — diskret und auf den Punkt.</p>
    </div>
</section>

<div class="hx-wrap" style="padding-bottom:clamp(70px,9vw,110px)">
    @if (Model.Count == 0)
    {
        <p class="hx-muted">Derzeit sind keine Beiträge veröffentlicht.</p>
    }
    else
    {
        <div class="hx-insights">
            @foreach (var a in Model)
            {
                <a class="hx-art" asp-controller="Blog" asp-action="Details" asp-route-slug="@a.Slug" data-reveal>
                    <div class="hx-art__media">
                        @if (!string.IsNullOrWhiteSpace(a.CoverUrl))
                        {
                            <img src="@a.CoverUrl" alt="@a.Titel" loading="lazy" />
                        }
                    </div>
                    <div class="hx-art__body">
                        <div class="hx-art__meta">
                            <span class="hx-art__cat">@(a.Kategorie ?? "Insight")</span>
                            <span class="hx-art__read">@a.LesezeitMinuten() Min.</span>
                        </div>
                        <h3>@a.Titel</h3>
                        @if (!string.IsNullOrWhiteSpace(a.Excerpt))
                        {
                            <p class="hx-art__excerpt">@a.Excerpt</p>
                        }
                        <span class="hx-art__date">@(a.PublishedAt?.ToString("dd. MMMM yyyy", new System.Globalization.CultureInfo("de-DE")))</span>
                    </div>
                </a>
            }
        </div>
    }
</div>
