@model PropertyDetailViewModel
@{
    var p = Model.Objekt;
    var bilder = p.Medien.Where(m => m.Typ == MediaType.Image).OrderBy(m => m.Reihenfolge).ToList();
    var cover = p.CoverUrl();
    var locked = Model.IstGesperrt;

    string BadgeBg(PropertyStatus s) => s switch
    {
        PropertyStatus.Verfuegbar => "#2F6B4F",
        PropertyStatus.Reserviert => "#96773A",
        PropertyStatus.Verkauft => "#5C5550",
        _ => "#181614"
    };
}

<div class="hx-wrap hx-dtop" x-data="{ lb: false, src: '' }">
    <a class="hx-back" asp-controller="Immobilien" asp-action="Index">&larr; Zurück zum Portfolio</a>

    <!-- Galerie -->
    <div class="hx-dgallery @(locked ? "is-locked" : "")">
        @if (cover != null)
        {
            <img src="@cover" alt="@p.Titel" @(locked ? "" : "@click=\"lb=true;src=$el.src\" style=cursor:zoom-in") />
        }
        else
        {
            <span class="hx-dgallery__ph"><img src="~/img/brand/baudorf-emblem-ink.png" alt="" /></span>
        }
        <span class="hx-dgallery__badge" style="background:@BadgeBg(p.Status)">@p.Status.Label()</span>
        @if (locked)
        {
            <div class="hx-dgallery__lock"><span style="font-size:1.6rem">&#128274;</span><span>Off-Market — Bilder nach Freigabe</span></div>
        }
    </div>
    @if (!locked && bilder.Count > 1)
    {
        <div class="hx-thumbs">
            @foreach (var b in bilder.Take(8))
            {
                <button type="button" class="hx-thumb" @@click="lb=true;src='@b.Url'"><img src="@(b.ThumbnailUrl ?? b.Url)" alt="@(b.Alt ?? p.Titel)" loading="lazy" /></button>
            }
        </div>
        <div class="hx-lightbox" x-show="lb" x-cloak @@click="lb=false" @@keydown.escape.window="lb=false">
            <img :src="src" alt="@p.Titel" />
            <button @@click="lb=false" aria-label="Schließen">&times;</button>
        </div>
    }

    <div class="hx-dbody">
        <div class="hx-dmain">
            <span class="hx-dmain__art">@p.Art.Label() · @(string.IsNullOrWhiteSpace(p.Region) ? p.Land : p.Region)</span>
            <h1>@p.Titel</h1>

            @if (locked)
            {
                <div class="hx-dgate" data-reveal>
                    <span style="font-size:1.7rem">&#128274;</span>
                    <h2>Vertrauliches Off-Market-Objekt</h2>
                    <p>Vollständige Kennzahlen, Unterlagen und Bilder sind ausschließlich vorgemerkten, freigegebenen Investoren zugänglich. Persönliche Freischaltung durch Andrea Krüger.</p>
                    @if (Model.IstAngemeldet)
                    {
                        <p style="color:var(--accent-lt)">Ihr Konto wartet noch auf Freigabe — wir prüfen Ihr Investitionsprofil.</p>
                    }
                    else
                    {
                        <a class="hx-btn hx-btn--gold hx-btn--gold-lt" asp-area="Identity" asp-page="/Account/Register">Jetzt registrieren</a>
                    }
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(p.Beschreibung))
            {
                <p class="hx-dmain__lead">@p.Beschreibung</p>
            }

            <h2>Objektdaten</h2>
            <dl class="hx-kuenye">
                <div><dt>Objektart</dt><dd>@p.Art.Label()</dd></div>
                <div><dt>Standort</dt><dd>@(string.IsNullOrWhiteSpace(p.Region) ? p.Land : p.Region)</dd></div>
                @if (locked)
                {
                    <div><dt>Kennzahlen</dt><dd>&#128274; nach Freigabe</dd></div>
                }
                else
                {
                    @if (p.Wohnflaeche.HasValue) { <div><dt>Wohnfläche</dt><dd>@DisplayHelpers.FlaecheText(p.Wohnflaeche)</dd></div> }
                    @if (p.Grundstuecksflaeche.HasValue) { <div><dt>Grundstück / GF</dt><dd>@DisplayHelpers.FlaecheText(p.Grundstuecksflaeche)</dd></div> }
                    @if (p.Baujahr.HasValue) { <div><dt>Baujahr</dt><dd>@p.Baujahr</dd></div> }
                    @if (p.Einheiten.HasValue) { <div><dt>Einheiten</dt><dd>@p.Einheiten</dd></div> }
                    @if (!string.IsNullOrWhiteSpace(p.Energieklasse)) { <div><dt>Energie / Standard</dt><dd>@p.Energieklasse</dd></div> }
                    @if (!string.IsNullOrWhiteSpace(p.Zustand)) { <div><dt>Zustand</dt><dd>@p.Zustand</dd></div> }
                }
            </dl>

            <h2>Lage</h2>
            <p class="hx-dmain__lead" style="margin-top:14px">Aus Diskretionsgründen zeigen wir nur die ungefähre Region. Die exakte Adresse erhalten vorgemerkte Investoren nach Freigabe.</p>
        </div>

        <aside class="hx-daside">
            <div class="hx-daside__card">
                <span class="hx-daside__lbl">Investment</span>
                <div class="hx-daside__kpi">
                    <div><small>Faktor</small><b class="gold">@(locked ? "—" : (p.Faktor?.ToString() ?? "—"))</b></div>
                    <div><small>Brutto-Rendite</small><b>@(locked ? "—" : (p.RenditeProzent.HasValue ? p.RenditeProzent + " %" : "—"))</b></div>
                </div>
                <div class="hx-daside__preis">
                    <small>Kaufpreis</small>
                    @if (locked)
                    {
                        <b class="blur">@(p.Kaufpreis.HasValue ? p.PreisText() : "Auf Anfrage")</b>
                    }
                    else
                    {
                        <b>@p.PreisText()</b>
                    }
                </div>
                @if (locked && !Model.IstAngemeldet)
                {
                    <a class="hx-btn hx-btn--gold" asp-area="Identity" asp-page="/Account/Register">Jetzt registrieren</a>
                }
                else
                {
                    <a class="hx-btn hx-btn--gold" asp-controller="Kontakt" asp-action="Index" asp-route-objekt="@p.Slug">Vertraulich anfragen</a>
                }
                <a class="hx-btn hx-btn--outline-dark" href="tel:+4901778387898">Andrea Krüger anrufen</a>
                <a class="hx-btn hx-btn--outline-dark" asp-controller="WhatsApp" asp-action="Chat" asp-route-objekt="@p.Id" target="_blank" rel="noopener">Per WhatsApp anfragen</a>
            </div>
            <div class="hx-daside__note">
                <span></span><span>Diskrete Bearbeitung — Reaktion i. d. R. innerhalb von 24 Stunden.</span>
            </div>
        </aside>
    </div>

    @if (Model.AehnlicheObjekte.Count > 0)
    {
        <div class="hx-similar">
            <h2>Ähnliche <em class="hx-em">Objekte</em></h2>
            <div class="hx-list" style="padding:0">
                @foreach (var s in Model.AehnlicheObjekte)
                {
                    var sc = s.CoverUrl();
                    <article class="hx-lcard">
                        <a class="hx-lcard__media" asp-controller="Immobilien" asp-action="Details" asp-route-slug="@s.Slug">
                            @if (sc != null) { <img src="@sc" alt="@s.Titel" loading="lazy" /> }
                            else { <span class="hx-lcard__ph"><img src="~/img/brand/baudorf-emblem-ink.png" alt="" /></span> }
                            <span class="hx-lcard__badge" style="background:@BadgeBg(s.Status)">@s.Status.Label()</span>
                        </a>
                        <div class="hx-lcard__body">
                            <span class="hx-lcard__ort">@(string.IsNullOrWhiteSpace(s.Region) ? s.Land : s.Region)</span>
                            <h3 class="hx-lcard__name"><a asp-controller="Immobilien" asp-action="Details" asp-route-slug="@s.Slug">@s.Titel</a></h3>
                        </div>
                    </article>
                }
            </div>
        </div>
    }
</div>
