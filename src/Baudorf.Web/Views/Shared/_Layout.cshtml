@inject ISiteSettings Settings
<!DOCTYPE html>
<html lang="de" data-pal="gold">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <partial name="_SeoMeta" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <noscript><style>[data-reveal]{opacity:1!important;transform:none!important}</style></noscript>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head>
<body>
    <header class="bd-nav" x-data="{ open: false, scrolled: false }"
            @@scroll.window="scrolled = (window.scrollY > 30)"
            :class="{ 'is-scrolled': scrolled }">
        <div class="bd-nav__inner">
            <a class="bd-nav__brand" asp-controller="Home" asp-action="Index" aria-label="Baudorf Startseite">
                <img src="~/img/brand/baudorf-logo-mark.png" alt="Baudorf Immobilien GmbH" />
            </a>

            <a class="bd-nav__phone" href="tel:@Settings.PhoneLink">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <span>@Settings.Get("contact.phone", "0177 – 838 78 98")</span>
            </a>

            <nav class="bd-nav__links" aria-label="Hauptnavigation">
                <a asp-controller="Home" asp-action="Index">Startseite</a>
                <a asp-controller="Immobilien" asp-action="Index">Immobilien</a>
                <a asp-controller="Home" asp-action="Index" asp-fragment="leistungen">Leistungen</a>
                <a asp-controller="Home" asp-action="Index" asp-fragment="ueber">Über uns</a>
                <a asp-controller="Kontakt" asp-action="Index">Kontakt</a>
                <a class="bd-nav__login" asp-area="Identity" asp-page="/Account/Login">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>Login
                </a>
                <a class="bd-nav__register" asp-area="Identity" asp-page="/Account/Register">Registrieren</a>
            </nav>

            <button class="bd-nav__burger" @@click="open = true" aria-label="Menü öffnen">
                <span></span><span></span><span></span>
            </button>
        </div>

        <!-- Mobile menu -->
        <div class="bd-mobile" x-show="open" x-cloak @@keydown.escape.window="open = false">
            <div class="bd-mobile__head">
                <img src="~/img/brand/baudorf-logo-mark.png" alt="Baudorf" height="34" />
                <button class="bd-mobile__close" @@click="open = false" aria-label="Menü schließen">&times;</button>
            </div>
            <nav class="bd-mobile__links">
                <a asp-controller="Home" asp-action="Index" @@click="open = false">Startseite</a>
                <a asp-controller="Immobilien" asp-action="Index" @@click="open = false">Immobilien</a>
                <a asp-controller="Home" asp-action="Index" asp-fragment="leistungen" @@click="open = false">Leistungen</a>
                <a asp-controller="Home" asp-action="Index" asp-fragment="ueber" @@click="open = false">Über uns</a>
                <a asp-controller="Kontakt" asp-action="Index" @@click="open = false">Kontakt</a>
            </nav>
            <div class="bd-mobile__actions">
                <a class="bd-mobile__login" asp-area="Identity" asp-page="/Account/Login" @@click="open = false">Login</a>
                <a class="bd-mobile__register" asp-area="Identity" asp-page="/Account/Register" @@click="open = false">Registrieren</a>
            </div>
            <a class="bd-mobile__phone" href="tel:@Settings.PhoneLink" @@click="open = false">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                @Settings.Get("contact.phone", "0177 – 838 78 98")
            </a>
        </div>
    </header>

    <main id="main">
        @RenderBody()
    </main>

    <footer class="bd-footer">
        <div class="bd-footer__grid">
            <div class="bd-footer__brand">
                <img src="~/img/brand/baudorf-logo-mark.png" alt="@Settings.Get("contact.company", "Baudorf Immobilien GmbH")" height="40" />
                <p>@Settings.Get("footer.intro", "Off-Market-Immobilien aus Velbert. Diskrete Vermarktung anspruchsvoller Wohn-, Gewerbe- und Kapitalanlageobjekte — seit 1994.")</p>
                <p class="bd-footer__slogan">@Settings.Get("brand.slogan", "Still, wirkungsvoll, mit Stil.")</p>
            </div>
            <div class="bd-footer__col">
                <span class="bd-footer__head">Immobilien</span>
                <a asp-controller="Immobilien" asp-action="Index">Off-Market</a>
                <a asp-controller="Immobilien" asp-action="Index">Kapitalanlagen</a>
                <a asp-controller="Immobilien" asp-action="Index">Gewerbe</a>
                <a asp-controller="Immobilien" asp-action="Index">Wohnimmobilien</a>
                <a asp-controller="Immobilien" asp-action="Index">Auslandsimmobilien</a>
            </div>
            <div class="bd-footer__col">
                <span class="bd-footer__head">Unternehmen</span>
                <a asp-controller="Home" asp-action="Index" asp-fragment="ueber">Über uns</a>
                <a asp-controller="Home" asp-action="Index" asp-fragment="leistungen">Leistungen</a>
                <a asp-controller="Blog" asp-action="Index">Aktuelles</a>
                <a asp-controller="Kontakt" asp-action="Index">Karriere</a>
                <a asp-controller="Kontakt" asp-action="Index">Tippgeber</a>
                <a asp-area="Admin" asp-controller="Home" asp-action="Index">Admin-Login</a>
            </div>
            <div class="bd-footer__col">
                <span class="bd-footer__head">Kontakt</span>
                <span>@Settings.Get("contact.street", "Auf der Egge 68")<br />@Settings.Get("contact.city", "42555 Velbert")</span>
                <a href="tel:@Settings.PhoneLink">@Settings.Get("contact.phone", "0177 – 838 78 98")</a>
                <a href="mailto:@Settings.Get("contact.email", "andrea.krueger@baudorf.de")">@Settings.Get("contact.email", "andrea.krueger@baudorf.de")</a>
                <span class="bd-footer__muted">@Settings.Get("contact.hours", "Mo–Fr · 09:00–18:00 Uhr")</span>
            </div>
        </div>
        <div class="bd-footer__legal">
            <span>&copy; @DateTime.Now.Year @Settings.Get("contact.company", "Baudorf Immobilien GmbH") · @Settings.Get("contact.cityShort", "Velbert")</span>
            <nav>
                <a asp-controller="Legal" asp-action="Impressum">Impressum</a>
                <a asp-controller="Legal" asp-action="Datenschutz">Datenschutz</a>
                <a asp-controller="Legal" asp-action="Agb">AGB</a>
                <a asp-controller="Widerruf" asp-action="Index">Vertrag widerrufen</a>
                <a href="#" onclick="if(window.BaudorfCookie){BaudorfCookie.open();}return false;">Cookie-Einstellungen</a>
            </nav>
        </div>
    </footer>

    @await Component.InvokeAsync("WhatsAppButton")
    <partial name="_CookieConsent" />

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
