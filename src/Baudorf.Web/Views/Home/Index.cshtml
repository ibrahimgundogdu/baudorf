@model HomeViewModel
@{
    ViewData["Title"] = null;
    string Url(string? u) => string.IsNullOrWhiteSpace(u) ? "#" : u;
    string BadgeBg(PropertyStatus s) => s switch
    {
        PropertyStatus.Verfuegbar => "#2F6B4F",
        PropertyStatus.Reserviert => "#96773A",
        PropertyStatus.Verkauft => "#5C5550",
        _ => "#181614"
    };
}

<div class="hx">

@{ var hero = Model.Sec("hero"); }
@if (hero is not null)
{
    <section class="hx-hero" x-data="{ i: 0, n: 4 }" x-init="setInterval(() => i = (i + 1) % n, 5500)">
        @{ var heroImgs = new[] { "/img/design/hero1.jpg", "/img/design/hero2.jpg", "/img/design/hero3.jpg", "/img/design/hero4.jpg" }; }
        @for (var hi = 0; hi < heroImgs.Length; hi++)
        {
            <img class="hx-hero__bg" :class="{ 'is-on': i === @hi }" src="@heroImgs[hi]" alt="" @(hi == 0 ? "fetchpriority=high" : "loading=lazy") />
        }
        <span class="hx-hero__veil hx-hero__veil--side"></span>
        <span class="hx-hero__veil hx-hero__veil--bottom"></span>
        <img class="hx-hero__emblem" src="~/img/brand/baudorf-emblem-cream.png" alt="" />
        <div class="hx-hero__inner">
            @if (!string.IsNullOrWhiteSpace(hero.Overline))
            {
                <div class="hx-eyebrow hx-hero__eyebrow"><span>@hero.Overline</span></div>
            }
            <h1 class="hx-h1">@Html.Raw(hero.Titel)</h1>
            <p class="hx-hero__lead">@hero.Text</p>
            <div class="hx-hero__cta">
                @if (!string.IsNullOrWhiteSpace(hero.CtaText)) { <a class="hx-btn hx-btn--gold" href="@Url(hero.CtaUrl)">@hero.CtaText <span>&rarr;</span></a> }
                @if (!string.IsNullOrWhiteSpace(hero.Cta2Text)) { <a class="hx-btn hx-btn--outline-light" href="@Url(hero.Cta2Url)">@hero.Cta2Text</a> }
            </div>
        </div>
        <div class="hx-hero__dots">
            @for (var hi = 0; hi < heroImgs.Length; hi++)
            {
                <button type="button" :class="{ 'is-on': i === @hi }" @@click="i = @hi" aria-label="Bild @(hi + 1)"></button>
            }
        </div>
        <div class="hx-hero__scroll"><span>Scrollen</span><span></span></div>
    </section>
}

@{ var philo = Model.Sec("philosophie"); }
@if (philo is not null)
{
    <section id="philosophie" class="hx-sec hx-sec--bg">
        <div class="hx-wrap">
            <div class="hx-split">
                <div class="hx-philo__text" data-reveal>
                    <div class="hx-eyebrow"><span>@philo.Overline</span></div>
                    <h2>@Html.Raw(philo.Titel)</h2>
                    @foreach (var para in (philo.Text ?? "").Split("\n\n", StringSplitOptions.RemoveEmptyEntries))
                    {
                        <p>@Html.Raw(para)</p>
                    }
                </div>
                <div class="hx-media" data-reveal>
                    @if (!string.IsNullOrWhiteSpace(philo.BildUrl))
                    {
                        <img src="@philo.BildUrl" alt="" loading="lazy" />
                    }
                    else
                    {
                        <span class="hx-media__emblem"><img src="~/img/brand/baudorf-emblem-gold.png" alt="" /></span>
                    }
                    <span class="hx-media__veil"></span>
                    <p class="hx-media__quote">„Still, wirkungsvoll,<br>mit Stil."</p>
                </div>
            </div>
        </div>
    </section>
}

@{ var leist = Model.Sec("leistungen"); }
@if (leist is not null)
{
    <section id="leistungen" class="hx-sec hx-sec--surface">
        <div class="hx-wrap">
            <div class="hx-head-row" data-reveal>
                <div>
                    <div class="hx-eyebrow"><span>@leist.Overline</span></div>
                    <h2 class="hx-h2">@Html.Raw(leist.Titel)</h2>
                </div>
                @if (!string.IsNullOrWhiteSpace(leist.Text)) { <p class="hx-head-row__desc">@leist.Text</p> }
            </div>
            <div class="hx-grid-cards">
                @{ var ln = 0; }
                @foreach (var item in leist.Items)
                {
                    <div class="hx-card" data-reveal>
                        <span class="hx-card__no">0@(++ln)</span>
                        <h3>@item.Titel</h3>
                        <p>@item.Text</p>
                        <span class="hx-card__more">Mehr erfahren &rarr;</span>
                    </div>
                }
                <a class="hx-card hx-card--dark" data-reveal asp-controller="Kontakt" asp-action="Index">
                    <span>Sprechen wir über Ihr Vorhaben.</span>
                    <span class="hx-card__more">Kontakt aufnehmen &rarr;</span>
                </a>
            </div>
        </div>
    </section>
}

<!-- AKTUELLE OBJEKTE (Mosaik) -->
@if (Model.FeaturedObjekte.Count > 0)
{
    <section id="objekte" class="hx-sec hx-sec--bg">
        <div class="hx-wrap">
            <div class="hx-head-row" data-reveal>
                <div>
                    <div class="hx-eyebrow"><span>Aktuelle Objekte</span></div>
                    <h2 class="hx-h2">Ausgewählte <em class="hx-em">Investments</em></h2>
                </div>
                <p class="hx-head-row__desc">Ein Auszug aus unserem Portfolio. Off-Market-Objekte sind sichtbar — ihre Kennzahlen vorgemerkten Investoren vorbehalten.</p>
            </div>
            <div class="hx-mosaic">
                @foreach (var p in Model.FeaturedObjekte.Take(6))
                {
                    var cover = p.CoverUrl();
                    <a class="hx-tile" data-reveal asp-controller="Immobilien" asp-action="Details" asp-route-slug="@p.Slug">
                        @if (cover != null)
                        {
                            <img class="hx-tile__img" src="@cover" alt="@p.Titel" loading="lazy" />
                        }
                        else
                        {
                            <span class="hx-tile__ph"><img src="~/img/brand/baudorf-emblem-ink.png" alt="" /></span>
                        }
                        <span class="hx-tile__veil"></span>
                        <span class="hx-tile__badge" style="background:@BadgeBg(p.Status)">@p.Status.Label()</span>
                        <div class="hx-tile__cap">
                            <span class="hx-tile__ort">@(string.IsNullOrWhiteSpace(p.Region) ? p.Land : p.Region)</span>
                            <h3 class="hx-tile__name">@p.Titel</h3>
                        </div>
                        <div class="hx-tile__slide">
                            <div>
                                <span class="hx-tile__badge" style="position:static;display:inline-block;background:@BadgeBg(p.Status);margin-bottom:16px">@p.Status.Label()</span>
                                <span class="hx-tile__ort">@(string.IsNullOrWhiteSpace(p.Region) ? p.Land : p.Region)</span>
                                <h3 class="hx-tile__name">@p.Titel</h3>
                            </div>
                            <div>
                                <div class="hx-tile__specs">
                                    @if (p.Wohnflaeche.HasValue) { <span>Wfl. <b>@DisplayHelpers.FlaecheText(p.Wohnflaeche)</b></span> }
                                    @if (p.Grundstuecksflaeche.HasValue) { <span>GF <b>@DisplayHelpers.FlaecheText(p.Grundstuecksflaeche)</b></span> }
                                    @if (p.Baujahr.HasValue) { <span>BJ <b>@p.Baujahr</b></span> }
                                </div>
                                <div class="hx-tile__foot">
                                    @if (p.IstOffMarket)
                                    {
                                        <span class="hx-tile__lock">&#128274; Für vorgemerkte Investoren</span>
                                    }
                                    else if (p.Faktor.HasValue)
                                    {
                                        <span class="hx-tile__faktor"><small>Faktor</small><b>@p.Faktor</b></span>
                                    }
                                    else
                                    {
                                        <span class="hx-tile__faktor"><small>Kaufpreis</small><b style="font-size:17px">@p.PreisText()</b></span>
                                    }
                                    <span class="hx-tile__det">Details &rarr;</span>
                                </div>
                            </div>
                        </div>
                    </a>
                }
            </div>
            <div class="hx-mosaic-more">
                <a class="hx-link" asp-controller="Immobilien" asp-action="Index">Alle Objekte ansehen &rarr;</a>
            </div>
        </div>
    </section>
}

@{ var stmt = Model.Sec("statement"); }
@if (stmt is not null)
{
    <section class="hx-band">
        @if (!string.IsNullOrWhiteSpace(stmt.BildUrl)) { <div class="hx-band__bg" style="background-image:url('@stmt.BildUrl')"></div> }
        <span class="hx-band__veil"></span>
        <img class="hx-band__emblem" src="~/img/brand/baudorf-emblem-cream.png" alt="" />
        <div class="hx-band__inner" data-reveal>
            <div class="hx-eyebrow hx-eyebrow--light hx-eyebrow--center"><span>@stmt.Overline</span></div>
            <h2>@Html.Raw(stmt.Titel)</h2>
            @if (!string.IsNullOrWhiteSpace(stmt.Text)) { <p>@stmt.Text</p> }
            @if (!string.IsNullOrWhiteSpace(stmt.CtaText)) { <a class="hx-btn hx-btn--gold hx-btn--gold-lt" href="@Url(stmt.CtaUrl)">@stmt.CtaText &rarr;</a> }
        </div>
    </section>
}

@{ var vorgehen = Model.Sec("vorgehen"); }
@if (vorgehen is not null)
{
    <section id="vorgehen" class="hx-sec hx-sec--bg">
        <div class="hx-wrap">
            <div class="hx-vorgehen__head" data-reveal>
                <div class="hx-eyebrow"><span>@vorgehen.Overline</span></div>
                <h2 class="hx-h2">@Html.Raw(vorgehen.Titel)</h2>
            </div>
            <div class="hx-timeline">
                <span class="hx-timeline__line"></span>
                <div class="hx-steps">
                    @{ var vn = 0; }
                    @foreach (var step in vorgehen.Items)
                    {
                        <div class="hx-step" data-reveal>
                            <div class="hx-step__circle"><span>0@(++vn)</span></div>
                            <h3>@step.Titel</h3>
                            <p>@step.Text</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>
}

@{ var klientel = Model.Sec("klientel"); }
@if (klientel is not null)
{
    <section class="hx-sec hx-sec--band hx-klientel">
        <img class="hx-klientel__emblem" src="~/img/brand/baudorf-emblem-gold.png" alt="" />
        <div class="hx-wrap" style="position:relative;z-index:1">
            <div class="hx-split">
                <div class="hx-klientel__intro" data-reveal>
                    <div class="hx-eyebrow"><span>@klientel.Overline</span></div>
                    <h2>@Html.Raw(klientel.Titel)</h2>
                    @if (!string.IsNullOrWhiteSpace(klientel.Text)) { <p>@klientel.Text</p> }
                </div>
                <div class="hx-klientel__list" data-reveal>
                    @{ var kn = 0; }
                    @foreach (var k in klientel.Items)
                    {
                        <div class="hx-klientel__row"><b>0@(++kn)</b><span>@k.Titel</span></div>
                    }
                </div>
            </div>
        </div>
    </section>
}

@{ var ueber = Model.Sec("ueber-uns"); var andrea = Model.Team.FirstOrDefault(); var ayla = Model.Team.Skip(1).FirstOrDefault(); }
@if (ueber is not null && andrea is not null)
{
    <section id="ueber" class="hx-sec hx-sec--surface">
        <div class="hx-wrap">
            <div class="hx-split hx-split--rev">
                <div class="hx-ueber__intro" data-reveal>
                    <div class="hx-eyebrow"><span>@ueber.Overline</span></div>
                    <h2>@andrea.Name</h2>
                    @if (!string.IsNullOrWhiteSpace(andrea.Rolle)) { <p class="hx-ueber__role">@andrea.Rolle</p> }
                    @foreach (var para in (andrea.Bio ?? "").Split("\n\n", StringSplitOptions.RemoveEmptyEntries))
                    {
                        <p>@para</p>
                    }
                    <div class="hx-ueber__stats">
                        <div><b>1994</b><small>Gegründet</small></div>
                        <div><b>Velbert</b><small>Sitz · NRW</small></div>
                    </div>
                </div>
                <div class="hx-ueber__photo" data-reveal>
                    @if (!string.IsNullOrWhiteSpace(andrea.FotoUrl)) { <img src="@andrea.FotoUrl" alt="@andrea.Name" /> }
                    <span class="hx-ueber__photo-veil"></span>
                    <div class="hx-ueber__photo-cap"><b>@andrea.Name</b><small>Geschäftsführerin</small></div>
                </div>
            </div>

            @if (ayla is not null)
            {
                <div class="hx-ayla" data-reveal>
                    @if (!string.IsNullOrWhiteSpace(ayla.FotoUrl)) { <img src="@ayla.FotoUrl" alt="@ayla.Name" /> }
                    <div class="hx-ayla__body">
                        <span>@ayla.Rolle</span>
                        <h3>@ayla.Name</h3>
                        @if (!string.IsNullOrWhiteSpace(ayla.Bio)) { <p>@ayla.Bio</p> }
                    </div>
                </div>
            }
        </div>
    </section>
}

@{ var zahlen = Model.Sec("zahlen"); var testi = Model.Sec("testimonial"); }
@if (zahlen is not null)
{
    <section id="bd-stats" class="hx-sec hx-sec--band">
        <div class="hx-wrap">
            <div class="hx-zahlen">
                @foreach (var z in zahlen.Items)
                {
                    <div class="hx-zahl" data-reveal>
                        <b>@Html.Raw(z.Titel)</b>
                        <span class="hx-zahl__line"></span>
                        <span>@z.Text</span>
                    </div>
                }
            </div>
            @if (testi is not null)
            {
                <div class="hx-testi" data-reveal>
                    <div style="display:flex;gap:50px;align-items:flex-start;justify-content:space-between">
                        <div class="hx-testi__quote">
                            <span class="hx-testi__mark">&ldquo;</span>
                            <p>@testi.Text</p>
                            <p class="hx-testi__who">@testi.Titel</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>
}

@{ var tipp = Model.Sec("tippgeber"); var karriere = Model.Sec("karriere"); }
@if (tipp is not null || karriere is not null)
{
    <section id="tippgeber" class="hx-sec hx-sec--bg">
        <div class="hx-wrap">
            <div class="hx-tk">
                @if (tipp is not null)
                {
                    <div class="hx-tk__cell hx-tk__cell--light" data-reveal>
                        <div>
                            <span class="lbl">@tipp.Overline</span>
                            <h3>@Html.Raw(tipp.Titel)</h3>
                            <p>@tipp.Text</p>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(tipp.CtaText)) { <a class="hx-btn hx-btn--gold" href="@Url(tipp.CtaUrl)">@tipp.CtaText &rarr;</a> }
                    </div>
                }
                @if (karriere is not null)
                {
                    <div class="hx-tk__cell hx-tk__cell--dark" data-reveal>
                        <div>
                            <span class="lbl">@karriere.Overline</span>
                            <h3>@Html.Raw(karriere.Titel)</h3>
                            <p>@karriere.Text</p>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(karriere.CtaText)) { <a class="hx-btn hx-btn--outline-light" href="@Url(karriere.CtaUrl)">@karriere.CtaText &rarr;</a> }
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- INSIGHTS -->
@{ var insSec = Model.Sec("insights"); }
@if (Model.Insights.Count > 0)
{
    <section id="insights" class="hx-sec hx-sec--surface">
        <div class="hx-wrap">
            <div class="hx-head-row" data-reveal>
                <div>
                    <div class="hx-eyebrow"><span>@(insSec?.Overline ?? "Markt & Insights")</span></div>
                    <h2 class="hx-h2">@Html.Raw(insSec?.Titel ?? "Expertenwissen für <em class=\"hx-em\">kluge Investoren</em>")</h2>
                </div>
                <a class="hx-link" asp-controller="Blog" asp-action="Index">Alle Beiträge &rarr;</a>
            </div>
            <div class="hx-insights">
                @foreach (var a in Model.Insights)
                {
                    <a class="hx-art" asp-controller="Blog" asp-action="Details" asp-route-slug="@a.Slug" data-reveal>
                        <div class="hx-art__media">
                            @if (!string.IsNullOrWhiteSpace(a.CoverUrl)) { <img src="@a.CoverUrl" alt="@a.Titel" loading="lazy" /> }
                        </div>
                        <div class="hx-art__body">
                            <div class="hx-art__meta">
                                <span class="hx-art__cat">@(a.Kategorie ?? "Insight")</span>
                                <span class="hx-art__read">@a.LesezeitMinuten() Min.</span>
                            </div>
                            <h3>@a.Titel</h3>
                            <span class="hx-art__date">@(a.PublishedAt?.ToString("dd. MMMM yyyy", new System.Globalization.CultureInfo("de-DE")))</span>
                        </div>
                    </a>
                }
            </div>
        </div>
    </section>
}

@{ var kontakt = Model.Sec("kontakt"); }
@if (kontakt is not null)
{
    <section id="kontakt" class="hx-kontakt">
        @if (!string.IsNullOrWhiteSpace(kontakt.BildUrl)) { <img class="hx-kontakt__bg" src="@kontakt.BildUrl" alt="" /> }
        <span class="hx-kontakt__veil"></span>
        <img class="hx-kontakt__emblem" src="~/img/brand/baudorf-emblem-cream.png" alt="" />
        <div class="hx-kontakt__inner">
            <div class="hx-kontakt__box" data-reveal>
                <div class="hx-eyebrow hx-eyebrow--light"><span>@kontakt.Overline</span></div>
                <h2>@Html.Raw(kontakt.Titel)</h2>
                <p>@kontakt.Text</p>
                <div class="hx-kontakt__cta">
                    @if (!string.IsNullOrWhiteSpace(kontakt.CtaText)) { <a class="hx-btn hx-btn--gold hx-btn--gold-lt" href="@Url(kontakt.CtaUrl)">@kontakt.CtaText &rarr;</a> }
                    <a class="hx-btn hx-btn--outline-light" href="tel:+4901778387898">Anrufen</a>
                </div>
            </div>
        </div>
    </section>
}

</div>
