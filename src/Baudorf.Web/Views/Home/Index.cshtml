@model HomeViewModel
@{
    ViewData["Title"] = null; // Startseite nutzt den Marken-Titel

    // CTA-Link normalisieren (interne "/#anchor" bleiben, sonst wie angegeben)
    string Url(string? u) => string.IsNullOrWhiteSpace(u) ? "#" : u;
}

@{ var hero = Model.Sec("hero"); }
@if (hero is not null)
{
    <section class="bd-hero">
        <div class="bd-hero__emblem" aria-hidden="true">
            <img src="~/img/brand/baudorf-emblem-gold.png" alt="" />
        </div>
        <div class="bd-container bd-hero__inner">
            @if (!string.IsNullOrWhiteSpace(hero.Overline)) { <span class="bd-overline bd-overline--light">@hero.Overline</span> }
            <h1 class="bd-hero__title">@Html.Raw(hero.Titel)</h1>
            <p class="bd-hero__lead">@hero.Text</p>
            <div class="bd-hero__cta">
                @if (!string.IsNullOrWhiteSpace(hero.CtaText)) { <a class="bd-btn bd-btn--gold" href="@Url(hero.CtaUrl)">@hero.CtaText</a> }
                @if (!string.IsNullOrWhiteSpace(hero.Cta2Text)) { <a class="bd-btn bd-btn--ghost" href="@Url(hero.Cta2Url)">@hero.Cta2Text</a> }
            </div>
        </div>
        <a class="bd-hero__scroll" href="#philosophie" aria-label="Nach unten scrollen"><span></span></a>
    </section>
}

@{ var philo = Model.Sec("philosophie"); }
@if (philo is not null)
{
    <section id="philosophie" class="bd-section bd-section--parch">
        <div class="bd-container bd-philo" data-reveal>
            @if (!string.IsNullOrWhiteSpace(philo.Overline)) { <span class="bd-overline">@philo.Overline</span> }
            <h2 class="bd-philo__head">@Html.Raw(philo.Titel)</h2>
            <p class="bd-philo__text">@philo.Text</p>
        </div>
    </section>
}

@{ var leist = Model.Sec("leistungen"); }
@if (leist is not null)
{
    <section id="leistungen" class="bd-section bd-section--white">
        <div class="bd-container">
            <div class="bd-sec-head" data-reveal>
                <span class="bd-overline">@leist.Overline</span>
                <h2>@Html.Raw(leist.Titel)</h2>
                @if (!string.IsNullOrWhiteSpace(leist.Text)) { <p class="bd-sec-head__sub">@leist.Text</p> }
            </div>
            <div class="bd-cards">
                @{ var i = 0; }
                @foreach (var item in leist.Items)
                {
                    <article class="bd-card-svc" data-reveal style="transition-delay:@(i * 70)ms">
                        <span class="bd-card-svc__num">@((++i).ToString("D2"))</span>
                        <h3>@item.Titel</h3>
                        <p>@item.Text</p>
                    </article>
                }
            </div>
        </div>
    </section>
}

<!-- Aktuelle Objekte (aus dem Immobilien-Modul) -->
@if (Model.FeaturedObjekte.Count > 0)
{
    <section id="objekte" class="bd-section bd-section--parch">
        <div class="bd-container">
            <div class="bd-sec-head bd-sec-head--row" data-reveal>
                <div>
                    <span class="bd-overline">Aktuelle Objekte</span>
                    <h2>Ausgewählte Immobilien</h2>
                </div>
                <a class="bd-link-gold" asp-controller="Immobilien" asp-action="Index">Alle Objekte ansehen &rarr;</a>
            </div>
            <div class="bd-objekte">
                @foreach (var p in Model.FeaturedObjekte)
                {
                    <partial name="_ObjektCard" model="p" />
                }
            </div>
        </div>
    </section>
}

@{ var vorgehen = Model.Sec("vorgehen"); }
@if (vorgehen is not null)
{
    <section class="bd-section bd-section--white">
        <div class="bd-container">
            <div class="bd-sec-head" data-reveal>
                <span class="bd-overline">@vorgehen.Overline</span>
                <h2>@Html.Raw(vorgehen.Titel)</h2>
            </div>
            <ol class="bd-steps">
                @{ var si = 0; }
                @foreach (var step in vorgehen.Items)
                {
                    <li class="bd-step" data-reveal style="transition-delay:@(si * 80)ms">
                        <span class="bd-step__num">@((++si).ToString("D2"))</span>
                        <h3>@step.Titel</h3>
                        <p>@step.Text</p>
                    </li>
                }
            </ol>
        </div>
    </section>
}

@{ var klientel = Model.Sec("klientel"); }
@if (klientel is not null)
{
    <section class="bd-section bd-section--ink">
        <div class="bd-container bd-klientel">
            <div class="bd-sec-head bd-sec-head--light" data-reveal>
                <span class="bd-overline bd-overline--light">@klientel.Overline</span>
                <h2>@Html.Raw(klientel.Titel)</h2>
            </div>
            <ul class="bd-klientel__list" data-reveal>
                @foreach (var item in klientel.Items)
                {
                    <li>@item.Titel</li>
                }
            </ul>
        </div>
    </section>
}

@{ var ueber = Model.Sec("ueber-uns"); }
@if (ueber is not null && Model.Team.Count > 0)
{
    <section id="ueber-uns" class="bd-section bd-section--parch">
        <div class="bd-container">
            <div class="bd-sec-head" data-reveal>
                <span class="bd-overline">@ueber.Overline</span>
                <h2>@Html.Raw(ueber.Titel)</h2>
            </div>
            <div class="bd-team">
                @foreach (var t in Model.Team)
                {
                    <article class="bd-team__card" data-reveal>
                        @if (!string.IsNullOrWhiteSpace(t.FotoUrl))
                        {
                            <img class="bd-team__foto" src="@t.FotoUrl" alt="@t.Name" loading="lazy" />
                        }
                        <div class="bd-team__body">
                            <h3>@t.Name</h3>
                            @if (!string.IsNullOrWhiteSpace(t.Rolle)) { <span class="bd-team__role">@t.Rolle</span> }
                            @if (!string.IsNullOrWhiteSpace(t.Bio)) { <p>@t.Bio</p> }
                        </div>
                    </article>
                }
            </div>
        </div>
    </section>
}

@{ var zahlen = Model.Sec("zahlen"); }
@if (zahlen is not null && zahlen.Items.Count > 0)
{
    <section class="bd-section bd-section--white">
        <div class="bd-container bd-zahlen">
            @{ var zi = 0; }
            @foreach (var z in zahlen.Items)
            {
                <div class="bd-zahl" data-reveal style="transition-delay:@(zi++ * 70)ms">
                    <span class="bd-zahl__num">@z.Titel</span>
                    <span class="bd-zahl__label">@z.Text</span>
                </div>
            }
        </div>
    </section>
}

@{ var tipp = Model.Sec("tippgeber"); }
@if (tipp is not null)
{
    <section id="tippgeber" class="bd-section bd-section--ink bd-cta-band">
        <div class="bd-container bd-cta-band__inner" data-reveal>
            <div>
                <span class="bd-overline bd-overline--light">@tipp.Overline</span>
                <h2>@Html.Raw(tipp.Titel)</h2>
                @if (!string.IsNullOrWhiteSpace(tipp.Text)) { <p>@tipp.Text</p> }
            </div>
            @if (!string.IsNullOrWhiteSpace(tipp.CtaText)) { <a class="bd-btn bd-btn--gold" href="@Url(tipp.CtaUrl)">@tipp.CtaText</a> }
        </div>
    </section>
}

@{ var kontakt = Model.Sec("kontakt"); }
@if (kontakt is not null)
{
    <section id="kontakt" class="bd-section bd-section--parch">
        <div class="bd-container bd-kontakt">
            <div class="bd-kontakt__text" data-reveal>
                <span class="bd-overline">@kontakt.Overline</span>
                <h2>@Html.Raw(kontakt.Titel)</h2>
                <p>@kontakt.Text</p>
                <ul class="bd-kontakt__meta">
                    <li><strong>@Model.S("contact.company", "Baudorf Immobilien GmbH")</strong></li>
                    <li>@Model.S("contact.street", "Auf der Egge 68") · @Model.S("contact.city", "42555 Velbert")</li>
                    <li><a href="tel:+4901778387898">@Model.S("contact.phone", "0177 – 838 78 98")</a></li>
                    <li><a href="mailto:@Model.S("contact.email", "andrea.krueger@baudorf.de")">@Model.S("contact.email", "andrea.krueger@baudorf.de")</a></li>
                    <li>@Model.S("contact.hours", "Mo–Fr · 09:00–18:00 Uhr")</li>
                </ul>
            </div>
            <div class="bd-kontakt__cta" data-reveal>
                <p>Schreiben Sie uns über unser Kontaktformular — vertraulich und unverbindlich.</p>
                @if (!string.IsNullOrWhiteSpace(kontakt.CtaText)) { <a class="bd-btn bd-btn--gold" href="@Url(kontakt.CtaUrl)">@kontakt.CtaText</a> }
                <a class="bd-btn bd-btn--outline" href="tel:+4901778387898">Andrea Krüger anrufen</a>
            </div>
        </div>
    </section>
}
