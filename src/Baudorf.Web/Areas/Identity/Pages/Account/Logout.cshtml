@page
@model LogoutModel
@{
    ViewData["Title"] = "Abmelden";
}

<section class="hx-pagehead">
    <div class="hx-wrap">
        <div class="hx-eyebrow"><span>Mein Konto</span></div>
        <h1>Ab&shy;melden</h1>
    </div>
</section>

<div class="hx-wrap">
    <div class="hx-auth hx-auth--center">
        <p>Möchten Sie sich von Ihrem Konto abmelden?</p>
        <form method="post">
            <button type="submit" class="hx-btn hx-btn--gold">Jetzt abmelden &rarr;</button>
        </form>
    </div>
</div>
