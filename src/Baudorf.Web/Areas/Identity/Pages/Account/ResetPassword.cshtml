@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Passwort zurücksetzen";
}

<section class="hx-pagehead">
    <img class="hx-pagehead__emblem" src="~/img/brand/baudorf-emblem-gold.png" alt="" />
    <div class="hx-wrap">
        <div class="hx-eyebrow"><span>Mein Konto</span></div>
        <h1>Neues <em class="hx-em">Passwort.</em></h1>
        <p>Vergeben Sie ein neues Passwort für Ihr Baudorf-Konto.</p>
    </div>
</section>

<div class="hx-wrap">
    <div class="hx-auth">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="hx-vsum"></div>
            <input asp-for="Input.Code" type="hidden" />

            <div class="hx-field">
                <label asp-for="Input.Email">E-Mail</label>
                <input asp-for="Input.Email" type="email" autocomplete="username" aria-required="true" placeholder="name@beispiel.de" />
                <span asp-validation-for="Input.Email"></span>
            </div>
            <div class="hx-frow">
                <div class="hx-field">
                    <label asp-for="Input.Password">Neues Passwort</label>
                    <input asp-for="Input.Password" autocomplete="new-password" aria-required="true" placeholder="Mind. 8 Zeichen" />
                    <span asp-validation-for="Input.Password"></span>
                </div>
                <div class="hx-field">
                    <label asp-for="Input.ConfirmPassword">Passwort bestätigen</label>
                    <input asp-for="Input.ConfirmPassword" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
                    <span asp-validation-for="Input.ConfirmPassword"></span>
                </div>
            </div>
            <div style="margin-top:1.4rem">
                <button type="submit" class="hx-btn hx-btn--gold">Passwort speichern &rarr;</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
}
