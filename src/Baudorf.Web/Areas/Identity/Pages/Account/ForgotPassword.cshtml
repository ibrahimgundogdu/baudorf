@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Passwort vergessen";
}

<section class="hx-pagehead">
    <img class="hx-pagehead__emblem" src="~/img/brand/baudorf-emblem-gold.png" alt="" />
    <div class="hx-wrap">
        <div class="hx-eyebrow"><span>Mein Konto</span></div>
        <h1>Passwort <em class="hx-em">vergessen.</em></h1>
        <p>Geben Sie Ihre E-Mail-Adresse ein. Wir senden Ihnen einen Link zum Zurücksetzen Ihres Passworts.</p>
    </div>
</section>

<div class="hx-wrap">
    <div class="hx-auth">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="hx-vsum"></div>
            <div class="hx-field">
                <label asp-for="Input.Email">E-Mail</label>
                <input asp-for="Input.Email" type="email" autocomplete="username" aria-required="true" placeholder="name@beispiel.de" />
                <span asp-validation-for="Input.Email"></span>
            </div>
            <div style="margin-top:1.4rem">
                <button type="submit" class="hx-btn hx-btn--gold">Link anfordern &rarr;</button>
            </div>
        </form>

        <p class="hx-auth__alt">
            <a asp-area="Identity" asp-page="/Account/Login">&larr; Zurück zur Anmeldung</a>
        </p>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
}
