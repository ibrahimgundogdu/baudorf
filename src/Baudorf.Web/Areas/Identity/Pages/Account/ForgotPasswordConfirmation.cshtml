@page
@model ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "E-Mail gesendet";
}

<section class="hx-pagehead">
    <img class="hx-pagehead__emblem" src="~/img/brand/baudorf-emblem-gold.png" alt="" />
    <div class="hx-wrap">
        <div class="hx-eyebrow"><span>Mein Konto</span></div>
        <h1>E-Mail <em class="hx-em">gesendet.</em></h1>
    </div>
</section>

<div class="hx-wrap">
    <div class="hx-auth hx-auth--center">
        <span class="hx-thanks__mark">&#10003;</span>
        <p>Falls ein Konto mit dieser E-Mail-Adresse existiert, haben wir Ihnen einen Link zum Zurücksetzen Ihres Passworts gesendet. Bitte prüfen Sie Ihr Postfach.</p>
        <div class="hx-auth__actions">
            <a class="hx-btn hx-btn--gold" asp-area="Identity" asp-page="/Account/Login">Zur Anmeldung</a>
            <a class="hx-btn hx-btn--outline-dark" asp-controller="Home" asp-action="Index">Zur Startseite</a>
        </div>
    </div>
</div>
