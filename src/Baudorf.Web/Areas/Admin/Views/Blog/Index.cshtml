@model List<BlogPost>
@{
    ViewData["Title"] = "Aktuelles / Insights";
}

<div class="bd-toolbar">
    <h2>Beiträge</h2>
    <a class="bd-btn bd-btn--gold bd-btn--sm" asp-action="Create">+ Neuer Beitrag</a>
</div>

<table class="bd-table">
    <thead>
        <tr><th></th><th>Titel</th><th>Kategorie</th><th>Status</th><th>Veröffentlicht</th><th></th></tr>
    </thead>
    <tbody>
        @if (Model.Count == 0)
        {
            <tr><td colspan="6" class="bd-empty-row">Noch keine Beiträge.</td></tr>
        }
        @foreach (var b in Model)
        {
            <tr>
                <td>@if (!string.IsNullOrWhiteSpace(b.CoverUrl)) { <img class="bd-thumb" src="@b.CoverUrl" alt="" /> }</td>
                <td><strong>@b.Titel</strong></td>
                <td>@(b.Kategorie ?? "—")</td>
                <td>
                    @if (b.IstVeroeffentlicht) { <span class="bd-pill bd-pill--ok">Veröffentlicht</span> }
                    else { <span class="bd-pill bd-pill--muted">Entwurf</span> }
                </td>
                <td>@(b.PublishedAt?.ToLocalTime().ToString("dd.MM.yyyy") ?? "—")</td>
                <td class="bd-table__actions">
                    <a class="bd-btn bd-btn--ink bd-btn--xs" asp-action="Edit" asp-route-id="@b.Id">Bearbeiten</a>
                    <form method="post" asp-action="Delete" asp-route-id="@b.Id" onsubmit="return confirm('Beitrag löschen?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="bd-btn bd-btn--danger bd-btn--xs">Löschen</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
