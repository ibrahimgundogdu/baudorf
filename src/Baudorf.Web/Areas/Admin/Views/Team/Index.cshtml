@model List<TeamMember>
@{
    ViewData["Title"] = "Team";
}

<div class="bd-toolbar">
    <h2>Team-Mitglieder</h2>
    <a class="bd-btn bd-btn--gold bd-btn--sm" asp-action="Create">+ Neues Mitglied</a>
</div>

<table class="bd-table">
    <thead><tr><th></th><th>Name</th><th>Rolle</th><th>Reihenfolge</th><th>Sichtbar</th><th></th></tr></thead>
    <tbody>
        @if (Model.Count == 0)
        {
            <tr><td colspan="6" class="bd-empty-row">Noch keine Team-Mitglieder.</td></tr>
        }
        @foreach (var t in Model)
        {
            <tr>
                <td>@if (!string.IsNullOrWhiteSpace(t.FotoUrl)) { <img class="bd-thumb" src="@t.FotoUrl" alt="" /> }</td>
                <td><strong>@t.Name</strong></td>
                <td>@(t.Rolle ?? "—")</td>
                <td>@t.Reihenfolge</td>
                <td>@(t.IstSichtbar ? "Ja" : "Nein")</td>
                <td class="bd-table__actions">
                    <a class="bd-btn bd-btn--ink bd-btn--xs" asp-action="Edit" asp-route-id="@t.Id">Bearbeiten</a>
                    <form method="post" asp-action="Delete" asp-route-id="@t.Id" onsubmit="return confirm('Mitglied löschen?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="bd-btn bd-btn--danger bd-btn--xs">Löschen</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
