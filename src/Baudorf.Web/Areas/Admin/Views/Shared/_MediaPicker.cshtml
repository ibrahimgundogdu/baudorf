@*
    Globaler Medien-Picker (vanilla JS). Öffnen via window.BaudorfMedia.open(cb).
    cb(url, asset) wird mit der gewählten/hochgeladenen Bild-URL aufgerufen.
*@
<div id="bd-media-picker" class="bd-mp" hidden
     data-list-url="@Url.Action("List", "Media", new { area = "Admin" })"
     data-upload-url="@Url.Action("Upload", "Media", new { area = "Admin" })">
    <div class="bd-mp__backdrop" data-mp-close></div>
    <div class="bd-mp__dialog" role="dialog" aria-modal="true" aria-label="Medien auswählen">
        <header class="bd-mp__head">
            <strong>Medien auswählen</strong>
            <button type="button" class="bd-mp__x" data-mp-close aria-label="Schließen">&times;</button>
        </header>
        <div class="bd-mp__tabs">
            <button type="button" class="bd-mp__tab is-active" data-mp-tab="library">Mediathek</button>
            <button type="button" class="bd-mp__tab" data-mp-tab="upload">Hochladen</button>
        </div>
        <div class="bd-mp__body">
            <div data-mp-panel="library" class="bd-mp__grid"></div>
            <div data-mp-panel="upload" hidden class="bd-mp__uploadpane">
                <label class="bd-media-drop">
                    <input type="file" id="bd-mp-file" accept="image/*" multiple />
                    <span>+ Bilder hochladen <small>(JPG/PNG/WebP, max. 12&nbsp;MB)</small></span>
                </label>
                <p class="bd-mp__status" data-mp-status></p>
            </div>
        </div>
    </div>
    @Html.AntiForgeryToken()
</div>
